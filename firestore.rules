rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owns(uid) { return signedIn() && request.auth.uid == uid; }
    function admin() { return signedIn() && request.auth.token.admin == true; }
    function protectedAccountFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['banned','suspended']);
    }

    match /users/{uid} {
      allow read: if owns(uid) || admin();
      allow create: if owns(uid)
        && !request.resource.data.keys().hasAny(['banned','suspended']);
      allow update: if admin() || (owns(uid) && protectedAccountFieldsUnchanged());
      allow delete: if admin();
      match /save/{section} {
        allow read, create, update, delete: if owns(uid) || admin();
      }
    }

    match /leaderboards/{uid} {
      allow read: if signedIn();
      allow create, update: if admin() || (owns(uid)
        && request.resource.data.uid == uid
        && request.resource.data.keys().hasOnly([
          'uid','displayName','totalLevel','combatLevel','coins','lifetimeGold',
          'totalKills','uniqueDrops','summonsUnlocked','deaths','skillLevels','highestSkill','updatedAt'
        ])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 24
        && request.resource.data.totalLevel is number
        && request.resource.data.combatLevel is number
        && request.resource.data.coins is number
        && request.resource.data.lifetimeGold is number
        && request.resource.data.totalKills is number);
      allow delete: if owns(uid) || admin();
    }

    match /system/{document} {
      allow read: if signedIn();
      allow write: if admin();
    }
    match /worldMaps/{document} { allow read, write: if admin(); }
    match /worldMapHistory/{document} { allow read, write: if admin(); }
    match /adminAudit/{document} { allow read: if admin(); allow write: if false; }
  }
}
