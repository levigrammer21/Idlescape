rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owns(uid) { return signedIn() && request.auth.uid == uid; }

    match /users/{uid} {
      allow read, create, update, delete: if owns(uid);
      match /save/{section} {
        allow read, create, update, delete: if owns(uid);
      }
    }

    match /leaderboards/{uid} {
      allow read: if signedIn();
      allow create, update: if owns(uid)
        && request.resource.data.uid == uid
        && request.resource.data.keys().hasOnly([
          'uid','displayName','totalLevel','combatLevel','coins','lifetimeGold',
          'totalKills','uniqueDrops','summonsUnlocked','skillLevels','highestSkill','updatedAt'
        ])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 24
        && request.resource.data.totalLevel is number
        && request.resource.data.combatLevel is number
        && request.resource.data.coins is number
        && request.resource.data.lifetimeGold is number
        && request.resource.data.totalKills is number;
      allow delete: if owns(uid);
    }
  }
}
